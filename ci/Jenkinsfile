pipeline {
  agent {
  kubernetes {
    yaml '''
      apiVersion: v1
      kind: Pod
      spec:
        containers:
        - name: tools
          image: radiance84/helep-jenkins-agent:latest
          imagePullPolicy: Always
          command: ["sleep"]
          args: ["infinity"]
          securityContext:
            runAsUser: 0
          volumeMounts:
          - name: docker-sock
            mountPath: /var/run/docker.sock
        volumes:
        - name: docker-sock
          hostPath:
            path: /var/run/docker.sock
    '''
    defaultContainer 'tools'
  }
}

  options {
    disableConcurrentBuilds()
  }

  parameters {
    string(name: 'DOCKER_NAMESPACE', defaultValue: 'radiance84', description: 'Docker Hub namespace/user')
    string(name: 'IMAGE_TAG', defaultValue: '0.1.0', description: 'Image tag to build/push/deploy')
  }

  environment {
    HELM_CHART = './charts/helep'
    RELEASE_NAME = 'helep'
    DEV_NAMESPACE = 'helep'
    PROD_NAMESPACE = 'prod'
    SERVICES = 'user-service sos-service dispatch-service notification-service analytics-service'
  }

  stages {
    stage('Lint Python') {
      steps {
        sh '''
          set -euo pipefail
          ruff check services
        '''
      }
    }

    stage('Build Docker Images') {
      steps {
        sh '''
          set -euo pipefail
          for svc in ${SERVICES}; do
            docker build -t ${DOCKER_NAMESPACE}/helep-${svc}:${IMAGE_TAG} services/${svc}
          done
        '''
      }
    }

    stage('Trivy Scan (HIGH+)') {
      steps {
        sh '''
          set -euo pipefail
          for svc in ${SERVICES}; do
            trivy image --severity HIGH,CRITICAL --exit-code 1 --ignore-unfixed ${DOCKER_NAMESPACE}/helep-${svc}:${IMAGE_TAG}
          done
        '''
      }
    }

    stage('Push Images') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKERHUB_USER', passwordVariable: 'DOCKERHUB_PASS')]) {
          sh '''
            set -euo pipefail
            echo "${DOCKERHUB_PASS}" | docker login -u "${DOCKERHUB_USER}" --password-stdin
            for svc in ${SERVICES}; do
              docker push ${DOCKER_NAMESPACE}/helep-${svc}:${IMAGE_TAG}
            done
          '''
        }
      }
    }

    stage('Deploy to helep Namespace') {
      steps {
        sh '''
          set -euo pipefail
          helm upgrade --install ${RELEASE_NAME} ${HELM_CHART} -n ${DEV_NAMESPACE} --create-namespace
        '''
      }
    }

    stage('Smoke Test /healthz') {
      steps {
        sh '''
          set -euo pipefail
          for expected in user-service sos-service dispatch-service notification-service analytics-service; do
            svc=$(kubectl -n ${DEV_NAMESPACE} get svc -o jsonpath='{range .items[*]}{.metadata.name}{"\n"}{end}' | grep "${expected}" | head -n1 || true)
            if [ -z "${svc}" ]; then
              echo "No Kubernetes Service found for ${expected}"
              exit 1
            fi
            port=$(kubectl -n ${DEV_NAMESPACE} get svc "${svc}" -o jsonpath='{.spec.ports[0].port}')
            pod="smoke-${expected}-$(date +%s)"
            kubectl -n ${DEV_NAMESPACE} run "${pod}" --restart=Never --rm --attach --image=curlimages/curl:8.8.0 -- \
              -fsS "http://${svc}:${port}/healthz"
          done
        '''
      }
    }

    stage('Manual Approval for Prod') {
      steps {
        input message: 'Deploy HELEP to prod namespace?', ok: 'Deploy to prod'
      }
    }

    stage('Deploy to prod Namespace') {
      steps {
        sh '''
          set -euo pipefail
          helm upgrade --install ${RELEASE_NAME} ${HELM_CHART} -n ${PROD_NAMESPACE} --create-namespace
        '''
      }
    }
  }
}